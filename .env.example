# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key

# API Authentication (optional - for programmatic API access)
# Comma-separated list of valid API keys
API_KEYS=

# Batch Processing
MAX_BATCH_SIZE=10

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_PRO=price_...

# App Identity (SEO)
NEXT_PUBLIC_APP_NAME=Transcrify
NEXT_PUBLIC_APP_URL=https://transcrify.com
NEXT_PUBLIC_APP_SLUG=transcrify

# AdSense (optional - set ADS_ENABLED=true after approval)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADS_ENABLED=false

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# CORS
ALLOWED_ORIGINS=https://transcrify.com
